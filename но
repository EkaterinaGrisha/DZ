import nltk
from nltk.corpus import stopwords
import pymorphy3
import re

nltk.download('stopwords')
morph = pymorphy3.MorphAnalyzer()
ru_stopwords = stopwords.words('russian')

# Настройка идиостиля: исключаем личные местоимения из стоп-слов
# Они часто являются маркерами авторского стиля (например, частота "я" или "он")
exclude_from_stopwords = {'я', 'меня', 'мне', 'ты', 'тебя', 'тебе', 'мы', 'вы', 'он', 'его', 'она', 'ее'}
custom_stopwords = [word for word in ru_stopwords if word not in exclude_from_stopwords]

def clean_and_lemmatize(text):
    # 1. Нормализация: нижний регистр и удаление всего, кроме букв
    text = re.sub(r'[^а-яА-ЯёЁ\s]', ' ', text.lower())
    
    # 2. Токенизация (разбиение на слова)
    words = text.split()
    
    # 3. Лемматизация и фильтрация стоп-слов
    cleaned_words = [
        morph.parse(word)[0].normal_form 
        for word in words 
        if word not in custom_stopwords and len(word) > 2
    ]
    
    return " ".join(cleaned_words)

# Применяем очистку (процесс может занять 1-2 минуты)
print("Запуск очистки и лемматизации...")
train_df['cleaned_text'] = train_df['text'].apply(clean_and_lemmatize)
print("Очистка завершена!")

