import pandas as pd

def generate_full_report(df, authors_dict):
    """
    Создает детализированную таблицу статистики с расширенной сеткой перцентилей.
    """
    # 1. Расчет базовых статистик и перцентилей по авторам
    author_stats = df.groupby('label')['word_count'].agg(['count', 'mean', 'min', 'max']).reset_index()
    
    # Расширенный набор квантилей
    quantiles = df.groupby('label')['word_count'].quantile([0.25, 0.5, 0.75, 0.95]).unstack()
    quantiles.columns = ['P25', 'P50 (Медиана)', 'P75', 'P95']
    
    author_stats = pd.concat([author_stats, quantiles.reset_index(drop=True)], axis=1)
    author_stats['Автор'] = author_stats['label'].map(authors_dict)
    
    # 2. Расчет итоговых показателей по всему корпусу
    total_q = df['word_count'].quantile([0.25, 0.5, 0.75, 0.95])
    total_row = pd.DataFrame({
        'Автор': ['ИТОГО ПО КОРПУСУ'],
        'count': [df.shape[0]],
        'mean': [df['word_count'].mean()],
        'min': [df['word_count'].min()],
        'max': [df['word_count'].max()],
        'P25': [total_q[0.25]],
        'P50 (Медиана)': [total_q[0.5]],
        'P75': [total_q[0.75]],
        'P95': [total_q[0.95]]
    })
    
    # 3. Объединение и переименование
    report = pd.concat([author_stats, total_row], ignore_index=True)
    report = report.rename(columns={
        'count': 'Кол-во фрагментов',
        'mean': 'Среднее (слов)',
        'min': 'Мин.',
        'max': 'Макс.'
    })
    
    # Упорядочиваем столбцы для логичного чтения
    cols = ['Автор', 'Кол-во фрагментов', 'Среднее (слов)', 'Мин.', 'P25', 'P50 (Медиана)', 'P75', 'P95', 'Макс.']
    return report[cols]

# Генерация отчета
