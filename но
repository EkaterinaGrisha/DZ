import pandas as pd

def prepare_data(folder, chunk_size=1000, step=500):
    # Словарь строго по заданию
    authors_map = {
        "Genri.txt": 0, "Simak.txt": 1, "Bulgakov.txt": 2,
        "Bradbury.txt": 3, "Fry.txt": 4, "Strugatskie.txt": 5
    }
    
    train_list = []
    
    for filename, label in authors_map.items():
        path = os.path.join(folder, filename)
        if os.path.exists(path):
            with open(path, 'r', encoding='utf-8') as f:
                # Читаем текст и убираем лишние пробелы/переносы
                text = " ".join(f.read().split())
                
                # Нарезка «скользящим окном»
                count = 0
                for i in range(0, len(text) - chunk_size, step):
                    train_list.append({
                        'text': text[i : i + chunk_size],
                        'label': label
                    })
                    count += 1
                print(f"Автор ID {label}: создано {count} фрагментов.")
    
    return pd.DataFrame(train_list)

# Создаем DataFrame
train_df = prepare_data(data_dir)

