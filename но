from collections import Counter

def plot_style_markers(df, authors_dict, pronouns_list):
    # Подготовка данных: считаем местоимения для каждого автора
    marker_data = []
    
    for auth_id, auth_name in authors_dict.items():
        # Собираем все слова автора в один список
        all_words = " ".join(df[df['label'] == auth_id]['cleaned_text']).split()
        counts = Counter(all_words)
        
        total_words = len(all_words)
        for p in pronouns_list:
            # Считаем относительную частоту (на 1000 слов), чтобы было честно
            frequency = (counts[p] / total_words) * 1000
            marker_data.append({
                'Автор': auth_name,
                'Местоимение': p,
                'Частота (на 1000 слов)': frequency
            })
    
    marker_df = pd.DataFrame(marker_data)

    # Визуализация
    plt.figure(figsize=(14, 6))
    sns.barplot(
        x='Местоимение', 
        y='Частота (на 1000 слов)', 
        hue='Автор', 
        data=marker_df,
        palette='viridis'
